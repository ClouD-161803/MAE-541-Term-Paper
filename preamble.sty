\newkeytheoremstyle{indentedStyle}
  {
    bodyfont=\rmfamily,
    leftmargin=0pt,
    rightmargin=0pt,
    headindent=0pt %If I want it to be in the normal spot, I have to set it to be the negative of the leftmargin value.
  }
  

\newkeytheorem{theorem}[style=indentedStyle, parent=section]
%"parent=section" means that the numbering will be chapter specific.

\newkeytheorem{corollary}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.

\newkeytheorem{lemma}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.

\newkeytheorem{proposition}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.

\newkeytheorem{example}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.

\newkeytheorem{definition}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.

\newkeytheorem{remark}[style=indentedStyle, sibling=theorem]
%"parent=chapter" means that the numbering will be chapter specific.


